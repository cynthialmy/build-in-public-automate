{
  "name": "build-in-public",
  "version": "0.3.0",
  "description": "CLI to automate build-in-public workflows — generate platform-tailored posts from git activity using Claude AI and publish to X, LinkedIn, Reddit, and HackerNews",
  "keywords": [
    "cli",
    "build-in-public",
    "devtools",
    "ai",
    "claude",
    "twitter",
    "x",
    "linkedin",
    "reddit",
    "hackernews",
    "git",
    "social-media",
    "automation"
  ],
  "author": "cynthialmy",
  "license": "MIT",
  "homepage": "https://github.com/cynthialmy/build-in-public-automate#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cynthialmy/build-in-public-automate.git"
  },
  "bugs": {
    "url": "https://github.com/cynthialmy/build-in-public-automate/issues"
  },
  "type": "module",
  "bin": {
    "bip": "dist/index.js"
  },
  "files": [
    "dist/",
    "templates/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "latest",
    "@inquirer/prompts": "^5.0.0",
    "chalk": "^5.0.0",
    "commander": "^12.0.0",
    "dotenv": "^17.3.1",
    "ora": "^8.0.0",
    "playwright": "^1.40.0",
    "simple-git": "^3.22.0",
    "snoowrap": "^1.23.0",
    "twitter-api-v2": "^1.17.0"
  },
  "devDependencies": {
    "@types/node": "^20.19.37",
    "@types/snoowrap": "^1.14.0",
    "@vitest/coverage-v8": "^1.6.1",
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "vitest": "^1.6.1"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
